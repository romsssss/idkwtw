{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "allowJs": true,
    "moduleResolution": "node16"
  },
  "include": ["src/**/*.ts", "config/**/*.ts", "app.ts", "jest.setup.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
