{
  "name": "idkwtw-front",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite-ssg build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@unhead/vue": "^2.1.13",
    "node-fetch": "^3.3.1",
    "pinia": "^3.0.4",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.0.0",
    "jsdom": "^29.0.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.0"
  }
}
